# Copy this file to .env and replace every placeholder before starting Docker Compose.
# Do not commit the resulting .env file.

DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
MYSQL_ROOT_PASSWORD=replace-with-a-strong-mysql-password
MYSQL_DATABASE=contract_agent
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
INTERNAL_API_KEY=replace-with-a-random-internal-api-key
FRONTEND_URL=http://localhost:5173
DIFY_TASK_OWNER_USERNAME=admin
